---
const navItems = [
  ['Tech Articles', '技术文章', '/blog/', 'code notes & ideas'],
  ['Life Records', '生活记录', '/life/', 'daily tiny moments'],
  ['Works Showcase', '作品展示', '/projects/', 'projects & practice'],
  ['Interest & Collections', '兴趣收藏', '/collections/', 'tools, books, links'],
  ['Links', '友链入口', '/links/', 'friends & sites'],
  ['About Me', '关于我', '/about/', 'soft sheep space']
];
const current = Astro.url.pathname;
const isCurrent = (href: string) => current === href || (href !== '/' && current.startsWith(href));
---
<header class="site-header" data-site-header>
  <div class="header-inner">
    <a class="brand" href="/" aria-label="返回首页">
      <span class="brand-mark home-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M4.5 11.2 12 5l7.5 6.2" />
          <path d="M6.8 10.4v8.1h10.4v-8.1" />
          <path d="M10.1 18.5v-4.7h3.8v4.7" />
        </svg>
      </span>
      <span>Soft Sheep</span>
    </a>
    <button
      class="menu-toggle"
      type="button"
      aria-label="打开导航菜单"
      aria-expanded="false"
      aria-controls="site-nav"
      data-menu-toggle
    >
      <span aria-hidden="true">☰</span>
    </button>
  </div>

  <nav id="site-nav" class="site-nav" aria-label="主导航" data-site-nav>
    {navItems.map(([label, cnLabel, href, hint]) => (
      <a class:list={['nav-link', isCurrent(href) ? 'active' : '']} href={href} aria-current={isCurrent(href) ? 'page' : undefined}>
        <span class="nav-label">{label}</span>
        <span class="nav-meta">{cnLabel}</span>
        <small>{hint}</small>
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 80;
    display: grid;
    grid-template-columns: minmax(172px, .42fr) minmax(0, 1fr);
    align-items: stretch;
    gap: 10px;
    width: min(1120px, 100%);
    min-height: 82px;
    padding: 7px 10px 8px;
    border: 2px solid rgba(31, 27, 22, .34);
    outline: 1px solid rgba(255, 253, 245, .78);
    outline-offset: -5px;
    border-radius: 0 0 30px 30px;
    background: transparent;
    box-shadow: 0 4px 20px rgba(31,27,22,.08);
    font-family: 'Baloo 2', 'Nunito', 'Arial Rounded MT Bold', 'Noto Sans SC', sans-serif;
    transition: transform .3s var(--ease-soft), border-color .3s ease, box-shadow .3s ease, min-height .3s var(--ease-soft);
  }

  :root[data-theme='dark'] .site-header {
    background: transparent;
    border-color: rgba(255, 211, 106, .58);
    outline-color: rgba(12, 12, 12, .64);
  }

  .site-header.is-scrolled {
    min-height: 74px;
    background: transparent;
    border-color: rgba(31, 27, 22, .42);
    box-shadow: 0 12px 34px rgba(95,75,50,.12);
    transform: translateX(-50%) translateY(2px);
  }

  :root[data-theme='dark'] .site-header.is-scrolled {
    background: transparent;
    border-color: rgba(255, 211, 106, .62);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    min-width: 0;
    padding: .58rem .72rem;
    border: 1px solid rgba(31, 27, 22, .18);
    border-radius: 26px;
    background: transparent;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: .58rem;
    min-width: max-content;
    color: var(--text-main);
    font-size: clamp(.98rem, 1.2vw, 1.1rem);
    font-weight: 900;
    letter-spacing: .01em;
    text-shadow: none;
    transform-origin: left center;
  }

  :root[data-theme='dark'] .brand { color: #ffffff; }

  .brand:hover {
    color: var(--color-caramel);
    transform: rotate(-2deg) scale(1.035);
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 16px 16px 18px 18px;
    background: linear-gradient(145deg, #fff7c8, #ffe49a 70%, #f7c948);
    color: #7a5521;
    box-shadow: inset 0 -4px 0 rgba(201,139,58,.12), 0 8px 18px rgba(247,201,72,.18);
  }

  .home-mark svg {
    width: 24px;
    height: 24px;
    fill: rgba(255,253,245,.56);
    stroke: currentColor;
    stroke-width: 2.05;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .site-nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    align-items: stretch;
    gap: 8px;
    min-width: 0;
  }

  .nav-link {
    position: relative;
    display: grid;
    align-content: center;
    gap: 1px;
    min-width: 0;
    min-height: 31px;
    padding: .3rem .58rem;
    border: 1px solid rgba(31, 27, 22, .2);
    border-radius: 22px;
    background: transparent;
    color: var(--text-main);
    overflow: hidden;
    text-align: left;
    text-shadow: none;
    transition: background .25s ease, color .25s ease, transform .25s var(--ease-soft), box-shadow .25s ease, border-color .25s ease;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: auto 10px 8px auto;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255,232,163,.2);
    box-shadow: -22px -12px 0 rgba(255,255,255,.12);
    opacity: .7;
    transition: transform .25s var(--ease-soft), opacity .25s ease;
  }

  .nav-label {
    position: relative;
    z-index: 1;
    display: block;
    font-size: clamp(.7rem, .8vw, .84rem);
    font-weight: 1000;
    line-height: 1.02;
    letter-spacing: -.015em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-meta,
  .nav-link small {
    position: relative;
    z-index: 1;
    display: block;
    color: var(--text-muted);
    font-family: 'LXGW WenKai Screen', 'Noto Sans SC', 'Microsoft YaHei', sans-serif;
    font-size: clamp(.54rem, .62vw, .62rem);
    font-weight: 800;
    line-height: 1.2;
  }

  .nav-link small {
    color: color-mix(in srgb, var(--text-muted) 76%, transparent);
    font-family: 'Baloo 2', 'Nunito', 'Noto Sans SC', sans-serif;
    letter-spacing: .02em;
  }

  :root[data-theme='dark'] .nav-link {
    background: transparent;
    color: #ffffff;
    border-color: rgba(255,255,255,.28);
  }

  :root[data-theme='dark'] .nav-meta,
  :root[data-theme='dark'] .nav-link small { color: rgba(255,255,255,.72); }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(255, 232, 163, .78);
    border-color: rgba(255,255,255,.82);
    color: #5a411f;
    transform: translateY(-2px) scale(1.018);
    box-shadow: 0 10px 22px rgba(247,201,72,.26);
    text-shadow: none;
  }

  .nav-link:hover::before,
  .nav-link.active::before {
    opacity: 1;
    transform: translate(-4px, -2px) scale(1.1);
    background: rgba(255,253,245,.42);
  }

  .nav-link:hover .nav-meta,
  .nav-link:hover small,
  .nav-link.active .nav-meta,
  .nav-link.active small {
    color: rgba(90,65,31,.72);
  }

  .menu-toggle {
    display: none;
    width: 42px;
    height: 42px;
    border: 0;
    border-radius: 50%;
    background: var(--color-butter);
    color: var(--text-main);
    font-weight: 900;
  }

  @media (max-width: 980px) {
    .site-header {
      width: min(100% - 18px, 760px);
      min-height: 62px;
      display: block;
      padding: 9px;
      border-radius: var(--radius-pill);
    }

    .header-inner {
      padding: 0;
      background: transparent;
      border-radius: var(--radius-pill);
    }

    .menu-toggle { display: grid; place-items: center; }

    .site-nav {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      display: none;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 12px;
      border: 1px solid rgba(31, 27, 22, .28);
      border-radius: var(--radius-lg);
      background: transparent;
      box-shadow: var(--shadow-card);
      backdrop-filter: blur(18px);
    }

    .site-nav.open { display: grid; animation: soft-pop .22s var(--ease-soft); }

    .nav-link {
      color: var(--text-main);
      text-shadow: none;
      background: transparent;
    }

    .nav-meta,
    .nav-link small { color: var(--text-muted); }
  }

  @media (max-width: 560px) {
    .site-nav { grid-template-columns: 1fr; }
    .nav-link { min-height: 58px; }
  }
</style>
