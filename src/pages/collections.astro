---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const items = await getCollection('collections');
const toTime = (date?: Date) => date?.getTime() || 0;
const withContentTime = <T extends { data: { pubDate?: Date; updatedDate?: Date } }>(item: T) => Math.max(toTime(item.data.updatedDate), toTime(item.data.pubDate));
const categories = [
  { key: 'all', label: '全部' },
  { key: 'tool', label: '工具' },
  { key: 'website', label: '网站' },
  { key: 'book', label: '书籍' },
  { key: 'anime', label: '动漫' },
  { key: 'sport', label: '运动' },
  { key: 'game', label: '游戏' },
  { key: 'tech', label: '技术' }
];
const typeLabels: Record<string, string> = {
  book: '书架',
  anime: '番剧',
  game: '游戏',
  tool: '工具',
  website: '网站',
  music: '音乐',
  other: '杂物盒',
  sport: '运动',
  tech: '技术'
};
const normalizedType = (type: string) => ['book', 'anime', 'game', 'tool', 'website', 'sport', 'tech'].includes(type) ? type : (type === 'music' ? 'tool' : 'tech');
const sortedItems = [...items].sort((a, b) => withContentTime(b) - withContentTime(a));
---
<BaseLayout title="Interest & Collections | 小羊草地" description="收藏喜欢的工具、网站、书籍、动漫、运动、游戏和技术内容。">
  <main class="collections-shell">
    <header class="collections-hero reveal-on-scroll">
      <div class="hero-copy">
        <span class="sticker-tag">Interest & Collections</span>
        <h1>兴趣收藏</h1>
        <p>搜索、分类、快速访问。</p>
      </div>
    </header>

    <section class="collection-controls soft-card reveal-on-scroll" aria-label="收藏搜索与分类">
      <label class="search-box">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.35-4.35"/><circle cx="11" cy="11" r="6.5"/></svg>
        <input type="search" placeholder="搜索收藏..." aria-label="搜索收藏" data-collection-search />
      </label>
      <div class="category-tabs" aria-label="收藏分类筛选">
        {categories.map((category) => (
          <button type="button" class="category-chip" data-filter={category.key} aria-pressed={category.key === 'all' ? 'true' : 'false'}>{category.label}</button>
        ))}
      </div>
    </section>

    <section class="collection-list" aria-label="收藏列表" data-collection-list>
      {sortedItems.map((item) => {
        const type = normalizedType(item.data.type);
        const label = typeLabels[type] || type;
        const keywords = [item.data.title, item.data.description, label, ...(item.data.tags || [])].filter(Boolean).join(' ');
        return (
          <a
            class="collection-row soft-card reveal-on-scroll"
            href={item.data.link || '/collections/'}
            data-category={type}
            data-keywords={keywords.toLowerCase()}
          >
            <span class={`row-type type-${type}`}>{label}</span>
            <span class="row-copy">
              <strong>{item.data.title}</strong>
              {item.data.description && <small>{item.data.description}</small>}
            </span>
            <span class="row-tags" aria-label="收藏标签">
              {(item.data.tags || []).slice(0, 3).map((tag) => <i>#{tag}</i>)}
            </span>
            <span class="row-rating" aria-label={item.data.rating ? `评分 ${item.data.rating} 星` : '未评分'}>
              {item.data.rating ? '★'.repeat(item.data.rating) : '—'}
            </span>
            <span class="row-arrow" aria-hidden="true">↗</span>
          </a>
        );
      })}
      <p class="empty-state" data-empty-state hidden>没有找到相关收藏。</p>
    </section>
  </main>
</BaseLayout>

<style>
  .collections-shell {
    width: var(--page-shell-width);
    margin-inline: auto;
    padding: 34px 0 84px;
  }

  .collections-hero { margin-bottom: 18px; }
  .hero-copy { padding: clamp(1rem, 3vw, 1.8rem) 0; }
  .hero-copy h1 {
    margin: .85rem 0 .75rem;
    font-size: clamp(1.3rem, 2.5vw, 2.65rem);
    line-height: 1.12;
    letter-spacing: -.03em;
  }
  .hero-copy p { margin: 0; color: var(--text-muted); font-weight: 800; }

  .collection-controls {
    display: grid;
    gap: .9rem;
    margin-bottom: 18px;
    padding: .95rem;
    border-radius: 28px;
    background: rgba(255,253,245,.86);
  }
  :root[data-theme='dark'] .collection-controls { background: rgba(12,12,12,.78); }

  .search-box {
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr);
    gap: .65rem;
    align-items: center;
    min-height: 44px;
    padding: 0 .85rem;
    border: 1px solid rgba(201,139,58,.22);
    border-radius: var(--radius-pill);
    background: rgba(255,250,240,.72);
  }
  :root[data-theme='dark'] .search-box { background: rgba(255,255,255,.08); }
  .search-box svg { width: 20px; height: 20px; fill: none; stroke: var(--color-caramel); stroke-width: 2; stroke-linecap: round; }
  .search-box input { width: 100%; border: 0; outline: 0; background: transparent; color: var(--text-main); font-weight: 850; }
  .search-box input::placeholder { color: var(--text-muted); }

  .category-tabs { display: flex; flex-wrap: wrap; gap: .5rem; }
  .category-chip {
    border: 1px solid rgba(201,139,58,.2);
    border-radius: var(--radius-pill);
    background: rgba(255,232,163,.34);
    color: var(--text-main);
    padding: .38rem .72rem;
    font-size: .88rem;
    font-weight: 900;
  }
  .category-chip[aria-pressed='true'] { background: var(--color-butter); color: #5a411f; box-shadow: 0 8px 18px rgba(247,201,72,.2); }

  .collection-list { display: grid; gap: 10px; }
  .collection-row {
    display: grid;
    grid-template-columns: 78px minmax(0, 1fr) minmax(110px, auto) 86px 34px;
    gap: .8rem;
    align-items: center;
    padding: .82rem .92rem;
    border-radius: 22px;
    color: inherit;
    background: rgba(255,253,245,.88);
  }
  :root[data-theme='dark'] .collection-row { background: rgba(12,12,12,.78); }
  .collection-row:hover { transform: translateX(4px); box-shadow: var(--shadow-lift); }

  .row-type {
    display: inline-grid;
    place-items: center;
    min-height: 34px;
    border-radius: 15px;
    background: rgba(255,232,163,.5);
    color: #6e4c1f;
    font-size: .84rem;
    font-weight: 950;
  }
  .type-website { background: rgba(205,239,255,.5); }
  .type-book { background: rgba(255,250,240,.84); }
  .type-anime { background: rgba(255,214,223,.52); }
  .type-sport { background: rgba(207,232,184,.58); }
  .type-game { background: rgba(229,220,255,.48); }
  .type-tech { background: rgba(255,232,163,.7); }

  .row-copy { display: grid; gap: .12rem; min-width: 0; }
  .row-copy strong { color: var(--text-main); font-size: clamp(1rem, 1.35vw, 1.22rem); line-height: 1.18; }
  .row-copy small { color: var(--text-muted); font-size: .88rem; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .row-tags { display: flex; flex-wrap: wrap; gap: .28rem; justify-content: flex-end; }
  .row-tags i { padding: .2rem .48rem; border-radius: var(--radius-pill); background: rgba(255,232,163,.26); color: var(--color-caramel); font-size: .76rem; font-style: normal; font-weight: 900; }
  .row-rating { color: var(--color-honey); font-size: .86rem; font-weight: 900; text-align: right; }
  .row-arrow { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 13px; background: rgba(255,232,163,.36); color: #6e4c1f; font-weight: 1000; }
  .empty-state { margin: 1rem 0 0; padding: 1rem; border-radius: 22px; background: rgba(255,253,245,.72); color: var(--text-muted); text-align: center; font-weight: 900; }

  @media (max-width: 820px) {
    .collection-row { grid-template-columns: 72px minmax(0, 1fr) 32px; }
    .row-tags,
    .row-rating { display: none; }
  }
  @media (max-width: 560px) {
    .collections-shell { width: calc(100% - 22px); padding-top: 40px; }
    .collection-row { grid-template-columns: 1fr 32px; }
    .row-type { justify-self: start; }
    .row-copy { grid-column: 1 / -1; }
  }
</style>

<script is:inline>
  (() => {
    const search = document.querySelector('[data-collection-search]');
    const chips = Array.from(document.querySelectorAll('[data-filter]'));
    const rows = Array.from(document.querySelectorAll('[data-category]'));
    const empty = document.querySelector('[data-empty-state]');
    if (!search || !rows.length) return;

    let active = 'all';
    const apply = () => {
      const query = search.value.trim().toLowerCase();
      let visibleCount = 0;
      rows.forEach((row) => {
        const matchCategory = active === 'all' || row.dataset.category === active;
        const matchQuery = !query || (row.dataset.keywords || '').includes(query);
        const show = matchCategory && matchQuery;
        row.hidden = !show;
        if (show) visibleCount += 1;
      });
      if (empty) empty.hidden = visibleCount !== 0;
    };

    search.addEventListener('input', apply);
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        active = chip.dataset.filter || 'all';
        chips.forEach((item) => item.setAttribute('aria-pressed', String(item === chip)));
        apply();
      });
    });
  })();
</script>
