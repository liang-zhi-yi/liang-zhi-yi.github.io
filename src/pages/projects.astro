---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate } from '../utils/date';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const statusText = {
  idea: '点子孵化',
  building: '正在搭建',
  done: '已经发布',
  archived: '归档留存'
};
const cardSizes = ['feature', 'wide', 'tall', 'compact', 'medium', 'wide'];
const coverTones = ['cover-honey', 'cover-sky', 'cover-grass', 'cover-pink'];
const imageModules = import.meta.glob('../../image/*.{png,jpg,jpeg,webp}', { eager: true, query: '?url', import: 'default' });
const imagePool = Object.values(imageModules) as string[];
const projectImage = (index: number) => imagePool[(index + 4) % imagePool.length] || '';
const statusSummary = projects.reduce<Record<string, number>>((summary, project) => {
  const status = project.data.status;
  summary[status] = (summary[status] || 0) + 1;
  return summary;
}, {});
const latestProject = projects[0]?.data.pubDate;
---
<BaseLayout title="Works Showcase | 小羊草地" description="以 Bento Grid 展示正在构建和已经完成的前端、内容与设计项目。">
  <main class="works-shell">
    <section class="works-hero reveal-on-scroll" aria-labelledby="works-title">
      <span class="sticker-tag">Works Showcase</span>
      <h1 id="works-title">作品展示</h1>
      <p>项目、状态、技术栈。</p>
    </section>

    <section class="works-info-board reveal-on-scroll" aria-label="作品展示信息看板">
      <div class="board-copy">
        <span>Works Index</span>
        <strong>{projects.length} 个项目条目</strong>
      </div>
      <dl class="board-stats">
        <div><dt>Works</dt><dd>{projects.length}</dd></div>
        <div><dt>Building</dt><dd>{statusSummary.building || 0}</dd></div>
        <div><dt>Done</dt><dd>{statusSummary.done || 0}</dd></div>
        <div><dt>Latest</dt><dd>{latestProject ? formatDate(latestProject) : '等待'}</dd></div>
      </dl>
    </section>

    <section class="bento-grid" aria-label="Bento Grid 项目展示">
      {projects.map((project, index) => {
        const size = cardSizes[index % cardSizes.length];
        const tone = coverTones[index % coverTones.length];
        return (
          <article class={`project-tile ${size} soft-card reveal-on-scroll`}>
            <a href={project.data.demoUrl || project.data.repoUrl || '/projects/'} class="tile-link">
              <div class={`project-cover ${tone}`} aria-hidden="true">
                {projectImage(index) && <img src={projectImage(index)} alt="" loading="lazy" />}
                <span>{statusText[project.data.status]}</span>
                <i>{String(index + 1).padStart(2, '0')}</i>
              </div>
              <div class="project-copy">
                <div class="project-meta">
                  <span>{statusText[project.data.status]}</span>
                  {project.data.role && <span>{project.data.role}</span>}
                  <time datetime={project.data.pubDate.toISOString()}>{formatDate(project.data.pubDate)}</time>
                </div>
                <h2>{project.data.title}</h2>
                <p>{project.data.description}</p>
                <div class="tech-stack">
                  {project.data.techStack.slice(0, 5).map((tech) => <span>{tech}</span>)}
                </div>
              </div>
            </a>
          </article>
        );
      })}

      <aside class="project-note soft-card reveal-on-scroll">
        <span>Showcase Note</span>
        <h2>保持简洁。</h2>
        <p>重点作品优先展示。</p>
      </aside>
    </section>
  </main>
</BaseLayout>

<style>
  .works-shell { width: var(--page-shell-width); margin-inline: auto; padding: clamp(30px, 5vw, 58px) 0 88px; }
  .works-hero { max-width: var(--page-core-width); margin: 0 auto clamp(1.6rem, 3.4vw, 2.6rem); text-align: center; }
  .works-hero h1 { margin: .85rem 0 .75rem; font-size: clamp(1.3rem, 2.5vw, 2.65rem); line-height: 1.12; letter-spacing: -.03em; }
  .works-hero p { max-width: 660px; margin: 0 auto; color: var(--text-muted); font-size: clamp(.96rem, 1.2vw, 1.06rem); }

  .works-info-board {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    margin: 0 0 clamp(1.2rem, 2.6vw, 2rem);
    padding: .95rem 1rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    background: rgba(255,253,245,.88);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(14px) saturate(126%);
  }
  :root[data-theme='dark'] .works-info-board { background: rgba(12,12,12,.78); }
  .board-copy { display: grid; gap: .18rem; }
  .board-copy span { color: var(--color-caramel); font-size: .72rem; font-weight: 950; letter-spacing: .16em; text-transform: uppercase; }
  .board-copy strong { color: var(--text-main); font-size: clamp(1.05rem, 1.5vw, 1.32rem); line-height: 1.18; }
  .board-copy p { margin: 0; color: var(--text-muted); font-size: .92rem; }
  .board-stats { display: grid; grid-template-columns: repeat(4, minmax(62px, 1fr)); gap: .5rem; margin: 0; }
  .board-stats div { padding: .55rem .65rem; border-radius: 18px; background: rgba(255,232,163,.34); text-align: center; }
  .board-stats dt { color: var(--text-muted); font-size: .68rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
  .board-stats dd { margin: .12rem 0 0; color: var(--text-main); font-family: 'Baloo 2', 'Nunito', sans-serif; font-size: 1rem; font-weight: 1000; line-height: 1.05; }

  .bento-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); grid-auto-rows: minmax(130px, auto); gap: clamp(.8rem, 1.4vw, 1.1rem); }
  .project-tile { min-height: 220px; padding: .78rem; color: var(--text-main); background: rgba(255,253,245,.9); overflow: hidden; }
  :root[data-theme='dark'] .project-tile { background: rgba(12,12,12,.82); }
  .project-tile.feature { grid-column: span 4; grid-row: span 2; min-height: 410px; }
  .project-tile.wide { grid-column: span 3; min-height: 250px; }
  .project-tile.tall { grid-column: span 2; grid-row: span 2; min-height: 380px; }
  .project-tile.medium { grid-column: span 3; min-height: 270px; }
  .project-tile.compact { grid-column: span 2; min-height: 230px; }
  .tile-link { display: grid; grid-template-rows: minmax(150px, .95fr) auto; height: 100%; color: inherit; gap: .9rem; }
  .project-tile.feature .tile-link { grid-template-columns: 1fr; grid-template-rows: minmax(210px, .95fr) auto; }
  .project-cover { position: relative; display: grid; align-content: space-between; min-height: 100%; padding: 1.1rem; border-radius: calc(var(--radius-lg) + 4px); overflow: hidden; background: rgba(255,232,163,.38); }
  .project-cover img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: saturate(.92) contrast(.96); transform: scale(1.03); }
  .project-cover::before { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,253,245,.18), rgba(90,65,31,.24)); z-index: 1; }
  .project-cover::after { content: ''; position: absolute; right: -34px; top: -28px; width: 170px; height: 170px; border-radius: 50%; background: rgba(255,255,255,.26); z-index: 1; }
  .project-cover span,
  .project-cover i { position: relative; z-index: 2; color: #fffdf5; font-weight: 950; text-shadow: 0 2px 12px rgba(90,65,31,.38); }
  .project-cover i { justify-self: end; align-self: end; font-family: 'Baloo 2', var(--font-display, system-ui), sans-serif; font-size: clamp(2.6rem, 5vw, 4.6rem); line-height: .8; font-style: normal; opacity: .38; }
  .cover-honey { background: linear-gradient(145deg, rgba(255,232,163,.96), rgba(255,250,240,.58)); }
  .cover-sky { background: linear-gradient(145deg, rgba(205,239,255,.88), rgba(255,250,240,.58)); }
  .cover-grass { background: linear-gradient(145deg, rgba(207,232,184,.9), rgba(255,250,240,.58)); }
  .cover-pink { background: linear-gradient(145deg, rgba(255,214,223,.88), rgba(255,250,240,.58)); }
  .project-copy { display: flex; flex-direction: column; justify-content: flex-end; padding: .2rem .25rem .35rem; }
  .project-meta { display: flex; flex-wrap: wrap; gap: .45rem .75rem; color: var(--color-caramel); font-size: .84rem; font-weight: 900; }
  .project-copy h2 { margin: .52rem 0 .34rem; font-size: clamp(1.22rem, 2vw, 2rem); line-height: 1.12; letter-spacing: -.035em; }
  .project-copy p { margin: 0; color: var(--text-muted); line-height: 1.68; }
  .tech-stack { display: flex; flex-wrap: wrap; gap: .45rem; margin-top: 1rem; }
  .tech-stack span { padding: .28rem .62rem; border-radius: var(--radius-pill); background: rgba(207,232,184,.54); color: var(--text-main); font-size: .82rem; font-weight: 900; }
  .project-note { grid-column: span 2; min-height: 230px; padding: 1.2rem; background: radial-gradient(circle at 85% 10%, rgba(255,232,163,.42), transparent 9rem), rgba(255,253,245,.9); }
  :root[data-theme='dark'] .project-note { background: radial-gradient(circle at 85% 10%, rgba(255,216,107,.13), transparent 9rem), rgba(12,12,12,.82); }
  .project-note span { color: var(--color-caramel); font-size: .78rem; font-weight: 950; letter-spacing: .14em; text-transform: uppercase; }
  .project-note h2 { margin: .7rem 0 .45rem; font-size: clamp(1.4rem, 2.4vw, 2.2rem); line-height: 1.08; }
  .project-note p { color: var(--text-muted); }

  @media (max-width: 980px) { .works-info-board { grid-template-columns: 1fr; } .board-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); } .bento-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .project-tile, .project-tile.feature, .project-tile.wide, .project-tile.tall, .project-tile.medium, .project-tile.compact, .project-note { grid-column: span 1; grid-row: auto; min-height: 260px; } .project-tile.feature .tile-link { grid-template-columns: 1fr; grid-template-rows: minmax(160px, .9fr) auto; } }
  @media (max-width: 620px) { .works-shell { width: calc(100% - 24px); } .bento-grid { grid-template-columns: 1fr; } }
</style>
