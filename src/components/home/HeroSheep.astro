---
---
<section class="hero hero-reference" id="home-top">
  <div class="hero-bg" aria-hidden="true">
    <span class="mist mist-a"></span>
    <span class="mist mist-b"></span>
    <span class="mist mist-c"></span>
    <span class="hero-spark spark-a">✦</span>
    <span class="hero-spark spark-b">✧</span>
    <span class="hero-spark spark-c">✦</span>
  </div>

  <div class="hero-frame reveal-on-scroll">
    <p class="hero-kicker">Welcome To My Soft Space</p>
    <h1 aria-label="Soft Sheep Blog">
      <span>Soft</span>
      <span>Sheep</span>
      <span>Blog</span>
    </h1>
    <p class="hero-subtitle">慢慢写代码，也慢慢记录生活。</p>
  </div>

  <a href="#home-sections" class="scroll-down" aria-label="滑入下方子页面" data-scroll-target="#home-sections">
    <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
      <path d="M12 5v13m0 0 6-6m-6 6-6-6" />
    </svg>
  </a>
</section>

<style>
  .hero-reference {
    position: relative;
    display: grid;
    place-items: center;
    min-height: calc(100svh - 104px);
    padding: clamp(42px, 8vh, 72px) 18px clamp(96px, 13vh, 120px);
    overflow: hidden;
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 50% 38%, rgba(255, 253, 245, .42), transparent 18rem),
      radial-gradient(circle at 24% 26%, rgba(255, 232, 163, .34), transparent 20rem),
      radial-gradient(circle at 82% 28%, rgba(255, 214, 223, .28), transparent 18rem);
  }

  .hero-bg::before,
  .hero-bg::after {
    content: '';
    position: absolute;
    border-radius: 999px;
    background: rgba(255, 253, 245, .52);
    box-shadow: var(--shadow-soft);
    filter: blur(.2px);
  }

  :root[data-theme='dark'] .hero-bg::before,
  :root[data-theme='dark'] .hero-bg::after {
    background: rgba(255, 224, 138, .13);
    box-shadow: 0 20px 70px rgba(0,0,0,.34);
  }

  .hero-bg::before {
    width: min(72vw, 920px);
    height: 150px;
    left: 50%;
    bottom: 9vh;
    transform: translateX(-50%);
    box-shadow: -360px 40px 0 rgba(255,255,255,.08), 360px 34px 0 rgba(255,255,255,.06);
    opacity: 0.35;
  }

  :root[data-theme='dark'] .hero-bg::before {
    box-shadow: -360px 40px 0 rgba(255,224,138,.03), 360px 34px 0 rgba(255,214,223,.02), 0 20px 70px rgba(0,0,0,.34);
    opacity: 0.25;
  }

  .hero-bg::after {
    display: none;
  }

  :root[data-theme='dark'] .hero-bg::after {
    display: none;
  }

  .mist,
  .hero-spark {
    position: absolute;
    pointer-events: none;
  }

  .mist {
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,.72), rgba(255,232,163,.2) 58%, transparent 70%);
  }

  :root[data-theme='dark'] .mist {
    background: radial-gradient(circle, rgba(255,224,138,.16), rgba(255,214,223,.08) 58%, transparent 72%);
  }

  .mist-a { width: 120px; height: 120px; left: 13%; top: 36%; }
  .mist-b { width: 58px; height: 58px; right: 19%; top: 30%; }
  .mist-c { width: 88px; height: 88px; right: 12%; bottom: 24%; }

  .hero-spark {
    color: rgba(255, 232, 163, .82);
    text-shadow: 0 0 22px rgba(247, 201, 72, .48);
    font-size: clamp(1.1rem, 2.6vw, 2.2rem);
    animation: cloud-drift 5s ease-in-out infinite alternate;
  }

  .spark-a { left: 23%; top: 24%; }
  .spark-b { right: 24%; top: 46%; animation-delay: -1.4s; }
  .spark-c { left: 28%; bottom: 22%; animation-delay: -2.2s; }

  .hero-frame {
    position: relative;
    width: min(760px, 100%);
    text-align: center;
    padding: clamp(.85rem, 2.2vw, 1.55rem);
  }

  .avatar-wrap {
    position: relative;
    width: clamp(108px, 12vw, 148px);
    height: clamp(108px, 12vw, 148px);
    margin: 0 auto .85rem;
  }

  .avatar-glow {
    position: absolute;
    inset: -18px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,232,163,.48), transparent 68%);
    filter: blur(2px);
  }

  .hero-avatar {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: linear-gradient(145deg, rgba(255,255,255,.88), rgba(255,232,163,.62));
    border: 4px solid rgba(255,255,255,.82);
    box-shadow: 0 28px 82px rgba(138,106,63,.2), inset 0 -14px 0 rgba(247,201,72,.11);
  }

  .cloud-ring {
    position: absolute;
    inset: 12px;
    border-radius: 42% 58% 48% 52%;
    background: var(--color-sheep-wool);
    box-shadow: inset 0 -10px 0 rgba(247,201,72,.1);
  }

  .mini-sheep { position: absolute; inset: 18px; }
  .mini-wool { position: absolute; inset: 22px 12px 12px; border-radius: 48% 52% 44% 56%; background: var(--color-sheep-wool); box-shadow: var(--shadow-card); }
  .mini-wool::before, .mini-wool::after { content: ''; position: absolute; top: -18px; width: 44px; height: 44px; border-radius: 50%; background: var(--color-sheep-wool); }
  .mini-wool::before { left: 24px; } .mini-wool::after { right: 24px; }
  .mini-ear { position: absolute; top: 54px; width: 32px; height: 48px; border-radius: 50%; background: var(--color-caramel); z-index: 0; }
  .mini-ear.left { left: 6px; transform: rotate(-24deg); } .mini-ear.right { right: 6px; transform: rotate(24deg); }
  .mini-face { position: absolute; left: 50%; top: 56%; width: 76px; height: 62px; transform: translate(-50%, -50%); border-radius: 50%; background: #ffe9bd; display: flex; justify-content: center; align-items: center; gap: 16px; }
  .mini-face span { width: 7px; height: 7px; border-radius: 50%; background: var(--text-main); transform: translateY(-6px); }
  .mini-face i { position: absolute; bottom: 16px; width: 24px; height: 12px; border-bottom: 3px solid var(--text-main); border-radius: 0 0 999px 999px; }

  .hero-kicker {
    margin: 0 0 .65rem;
    color: #fff1a8;
    font-family: 'Baloo 2', 'Nunito', 'Arial Rounded MT Bold', 'Noto Sans SC', sans-serif;
    font-size: clamp(.76rem, 1.1vw, .94rem);
    font-weight: 900;
    letter-spacing: .18em;
    text-transform: uppercase;
    text-shadow: 0 3px 16px rgba(95,75,50,.32), 0 0 18px rgba(247,201,72,.42);
  }

  .hero-frame h1 {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: .14em;
    margin: 0;
    font-family: 'Baloo 2', 'Nunito', 'Arial Rounded MT Bold', 'Noto Sans SC', sans-serif;
    font-size: clamp(1.8rem, 5vw, 3.95rem);
    font-weight: 900;
    line-height: .92;
    letter-spacing: -.052em;
    color: #fff3ad;
    -webkit-text-stroke: 1px rgba(255,255,255,.62);
    text-shadow:
      0 5px 0 rgba(201,139,58,.22),
      0 14px 32px rgba(95,75,50,.3),
      0 0 30px rgba(247,201,72,.38);
  }

  .hero-frame h1 span {
    display: inline-block;
    transition: transform .28s var(--ease-soft), color .28s ease, text-shadow .28s ease;
  }

  .hero-frame h1 span:hover {
    transform: translateY(-6px) scale(1.05) rotate(-1deg);
    color: #fff8c9;
    text-shadow:
      0 8px 0 rgba(201,139,58,.22),
      0 20px 42px rgba(95,75,50,.38),
      0 0 46px rgba(255,232,163,.7);
  }

  .hero-subtitle {
    margin: .75rem auto 0;
    color: rgba(255, 253, 245, .96);
    font-size: clamp(.92rem, 1.35vw, 1.1rem);
    font-weight: 900;
    text-shadow: 0 4px 18px rgba(95,75,50,.38);
  }

  .hero-description {
    max-width: 520px;
    margin: .42rem auto 0;
    color: rgba(255, 253, 245, .86);
    font-family: 'Baloo 2', 'Nunito', 'Noto Sans SC', sans-serif;
    font-size: clamp(.78rem, 1.05vw, .92rem);
    font-weight: 800;
    line-height: 1.65;
    text-shadow: 0 3px 16px rgba(95,75,50,.34);
  }

  .scroll-down {
    position: absolute;
    left: 50%;
    bottom: clamp(58px, 8.5svh, 86px);
    transform: translateX(-50%);
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border: 1px solid rgba(255,255,255,.88);
    border-radius: 50%;
    background: rgba(255,253,245,.72);
    color: var(--color-caramel);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(14px);
    animation: arrow-breathe 1.8s ease-in-out infinite;
    text-decoration: none;
  }

  .scroll-down svg {
    width: 26px;
    height: 26px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform .25s var(--ease-soft), stroke-width .25s ease;
  }

  .scroll-down:hover {
    transform: translateX(-50%) scale(1.18);
    background: var(--color-honey);
    color: #5a411f;
    box-shadow: 0 18px 42px rgba(247,201,72,.42);
    border-color: rgba(255,255,255,.96);
    animation-play-state: paused;
  }

  .scroll-down:hover svg {
    transform: translateY(3px) scale(1.08);
    stroke-width: 3.2;
  }

  @keyframes arrow-breathe {
    0%, 100% { translate: 0 0; box-shadow: var(--shadow-soft); }
    50% { translate: 0 8px; box-shadow: var(--shadow-lift); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-spark,
    .mist {
      animation: none;
    }
    .scroll-down {
      animation: none;
    }
    .hero-frame h1 span {
      transition: none;
    }
  }

  @media (max-width: 760px) {
    .hero-reference { padding-top: 96px; padding-bottom: 116px; }
    .hero-frame h1 { display: grid; gap: .02em; font-size: clamp(1.95rem, 9vw, 3rem); }
    .hero-description { max-width: 92%; }
    .scroll-down { bottom: 44px; width: 50px; height: 50px; }
  }
</style>
