---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/blog/ReadingProgress.astro';
import PostToc from '../components/blog/PostToc.astro';
import { formatDate } from '../utils/date';

export interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  cover?: string;
}
const { title, description, pubDate, updatedDate, tags = [], cover } = Astro.props;
---
<BaseLayout title={`${title} | 小羊草地`} description={description} type="article" image={cover}>
  <ReadingProgress />
  <article class="post-shell container">
    <!-- 标题区：居中放大，信息层级清晰 -->
    <header class="post-hero reveal-on-scroll">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta-line">
        {pubDate && (
          <span class="meta-item">
            <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          </span>
        )}
        {updatedDate && (
          <span class="meta-item">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            <span>更新于 {formatDate(updatedDate)}</span>
          </span>
        )}
        {tags.length > 0 && (
          <span class="meta-item meta-tags">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><circle cx="7" cy="7" r="1"/></svg>
            {tags.map((tag, i) => (
              <span class="tag-link">{tag}{i < tags.length - 1 ? ' · ' : ''}</span>
            ))}
          </span>
        )}
      </div>
    </header>

    <!-- 移动端目录切换按钮 -->
    <button class="toc-toggle-mobile" type="button" aria-label="展开/收起文章目录" aria-expanded="false" aria-controls="post-toc" data-toc-toggle>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
      <span>目录</span>
    </button>

    <div class="post-grid">
      <div class="prose soft-card post-content reveal-on-scroll" data-post-content>
        <slot />
      </div>
      <PostToc />
    </div>
  </article>
</BaseLayout>

<script>
  // 移动端目录切换
  const tocToggle = document.querySelector('[data-toc-toggle]');
  const toc = document.querySelector('[data-post-toc]');
  
  if (tocToggle && toc) {
    tocToggle.addEventListener('click', () => {
      const isExpanded = tocToggle.getAttribute('aria-expanded') === 'true';
      tocToggle.setAttribute('aria-expanded', String(!isExpanded));
      toc.classList.toggle('is-mobile-open', !isExpanded);
    });

    // 点击目录链接后自动关闭移动端目录
    toc.addEventListener('click', (e) => {
      if (e.target instanceof HTMLElement && e.target.closest('a')) {
        tocToggle.setAttribute('aria-expanded', 'false');
        toc.classList.remove('is-mobile-open');
      }
    });
  }
</script>

<style>
  .post-shell {
    width: min(960px, 94vw);
    padding: 42px 0 52px;
  }

  /* ===== 标题区优化 ===== */
  .post-hero {
    width: min(760px, 90vw);
    padding: 2.5rem 2rem 2rem;
    margin: 0 auto 32px;
    text-align: center;
    background: rgba(255, 253, 245, .92);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(247, 201, 72, .25);
    box-shadow: 0 8px 32px rgba(138, 106, 63, .08);
  }

  :root[data-theme='dark'] .post-hero {
    background: rgba(12, 12, 12, .86);
    border-color: rgba(255, 224, 138, .15);
  }

  .post-title {
    margin: 0 0 1.25rem;
    color: var(--text-main);
    font-size: clamp(1.85rem, 4vw, 2.6rem);
    line-height: 1.18;
    font-weight: 950;
    letter-spacing: -.02em;
  }

  .post-meta-line {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: .35rem 1.2rem;
    color: var(--text-muted);
    font-size: .875rem;
    font-weight: 500;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
  }

  .meta-item svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: .7;
  }

  .meta-tags {
    color: var(--color-caramel);
  }

  .tag-link {
    transition: color 180ms ease;
  }

  .tag-link:hover {
    color: var(--text-main);
  }

  /* ===== 移动端目录切换按钮 ===== */
  .toc-toggle-mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    width: min(760px, 90vw);
    margin: 0 auto 16px;
    padding: .75rem 1rem;
    border: 1px solid rgba(247, 201, 72, .4);
    border-radius: var(--radius-lg);
    background: rgba(255, 253, 245, .9);
    color: var(--color-caramel);
    font-size: .95rem;
    font-weight: 850;
    cursor: pointer;
    transition: all 200ms ease;
  }

  .toc-toggle-mobile svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .toc-toggle-mobile:hover {
    background: rgba(255, 248, 220, .95);
    border-color: rgba(247, 201, 72, .7);
    transform: translateY(-1px);
  }

  .toc-toggle-mobile[aria-expanded="true"] {
    background: rgba(255, 232, 163, .5);
    border-color: rgba(247, 201, 72, .8);
  }

  :root[data-theme='dark'] .toc-toggle-mobile {
    background: rgba(12, 12, 12, .8);
    border-color: rgba(255, 224, 138, .25);
  }

  :root[data-theme='dark'] .toc-toggle-mobile:hover {
    background: rgba(255, 224, 138, .1);
    border-color: rgba(255, 224, 138, .4);
  }

  @media (min-width: 1100px) {
    .toc-toggle-mobile { display: none; }
  }

  /* ===== 文章网格布局 ===== */
  .post-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }

  @media (min-width: 1100px) {
    .post-grid {
      grid-template-columns: minmax(0, 720px) 200px;
      justify-content: center;
      gap: 48px;
    }
  }

  @media (min-width: 1280px) {
    .post-grid {
      grid-template-columns: minmax(0, 760px) 220px;
      gap: 56px;
    }
  }

  /* ===== 正文内容区优化 ===== */
  .post-content {
    width: 100%;
    padding: 2.5rem 2.25rem;
    margin: 0 auto;
    background: rgba(255, 253, 245, .92);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(247, 201, 72, .2);
    box-shadow: 0 8px 32px rgba(138, 106, 63, .06);
  }

  @media (max-width: 1099px) {
    .post-content {
      width: min(760px, 90vw);
    }
  }

  :root[data-theme='dark'] .post-content {
    background: rgba(12, 12, 12, .86);
    border-color: rgba(255, 224, 138, .12);
  }

  /* 正文基础排版 */
  .post-content :global(p) {
    margin: 0 0 1.5em;
    color: var(--text-main);
    font-size: 1.05rem;
    line-height: 1.7;
    text-align: justify;
    text-align-last: left;
  }

  .post-content :global(p:last-child) {
    margin-bottom: 0;
  }

  /* 一级标题 */
  .post-content :global(h1) {
    margin: 2.5em 0 1em;
    color: var(--text-main);
    font-size: 1.65rem;
    line-height: 1.25;
    font-weight: 950;
    letter-spacing: -.015em;
  }

  .post-content :global(h1:first-child) {
    margin-top: 0;
  }

  /* 二级标题：左侧竖线装饰 */
  .post-content :global(h2) {
    margin: 2.5em 0 1em;
    padding: 0 0 0 1rem;
    color: var(--text-main);
    font-size: 1.35rem;
    line-height: 1.3;
    font-weight: 950;
    letter-spacing: -.01em;
    border-left: 4px solid rgba(247, 201, 72, .7);
  }

  :root[data-theme='dark'] .post-content :global(h2) {
    border-left-color: rgba(255, 224, 138, .5);
  }

  /* 三级标题 */
  .post-content :global(h3) {
    margin: 2em 0 .85em;
    color: var(--text-main);
    font-size: 1.15rem;
    line-height: 1.35;
    font-weight: 900;
  }

  /* 四级标题 */
  .post-content :global(h4) {
    margin: 1.75em 0 .75em;
    color: var(--text-main);
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 880;
  }

  /* 列表样式 */
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 0 0 1.5em;
    padding-left: 1.75rem;
  }

  .post-content :global(li) {
    margin: 0 0 .6em;
    color: var(--text-main);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .post-content :global(li:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(li > ul),
  .post-content :global(li > ol) {
    margin-top: .6em;
    margin-bottom: 0;
  }

  /* 引用块 */
  .post-content :global(blockquote) {
    margin: 1.5em 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid rgba(247, 201, 72, .6);
    border-radius: 0 12px 12px 0;
    background: rgba(255, 248, 220, .5);
  }

  :root[data-theme='dark'] .post-content :global(blockquote) {
    background: rgba(255, 224, 138, .08);
    border-left-color: rgba(255, 224, 138, .4);
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* 代码块 */
  .post-content :global(pre) {
    margin: 1.5em 0;
    padding: 1.25rem;
    border-radius: 12px;
    background: rgba(255, 248, 220, .7);
    overflow-x: auto;
  }

  :root[data-theme='dark'] .post-content :global(pre) {
    background: rgba(0, 0, 0, .3);
  }

  .post-content :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
    font-size: .9em;
  }

  .post-content :global(:not(pre) > code) {
    padding: .2em .4em;
    border-radius: 6px;
    background: rgba(247, 201, 72, .2);
    color: var(--color-caramel);
  }

  /* 链接 */
  .post-content :global(a) {
    color: var(--color-caramel);
    text-decoration: underline;
    text-decoration-color: rgba(182, 120, 36, .3);
    text-underline-offset: .2em;
    transition: all 180ms ease;
  }

  .post-content :global(a:hover) {
    text-decoration-color: var(--color-caramel);
  }

  /* 图片 */
  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 1.5em 0;
  }

  /* 分隔线 */
  .post-content :global(hr) {
    margin: 2.5em 0;
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201, 139, 58, .3), transparent);
  }

  /* 表格 */
  .post-content :global(table) {
    width: 100%;
    margin: 1.5em 0;
    border-collapse: collapse;
    font-size: .95rem;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: .75rem 1rem;
    border: 1px solid rgba(201, 139, 58, .2);
    text-align: left;
  }

  .post-content :global(th) {
    background: rgba(255, 248, 220, .5);
    font-weight: 850;
  }

  :root[data-theme='dark'] .post-content :global(th) {
    background: rgba(255, 224, 138, .1);
  }

  /* 响应式调整 */
  @media (max-width: 760px) {
    .post-shell { width: 100%; padding-top: 24px; }
    
    .post-hero {
      width: calc(100% - 24px);
      padding: 1.75rem 1.25rem 1.5rem;
      margin-bottom: 20px;
    }

    .post-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
      margin-bottom: 1rem;
    }

    .post-meta-line {
      font-size: .8rem;
      gap: .5rem .8rem;
    }

    .post-content {
      width: calc(100% - 24px);
      padding: 1.5rem 1.25rem;
    }

    .post-content :global(p),
    .post-content :global(li) {
      font-size: 1rem;
      line-height: 1.75;
    }

    .post-content :global(h2) {
      font-size: 1.2rem;
      padding-left: .75rem;
      margin: 2em 0 .85em;
    }

    .post-content :global(h3) {
      font-size: 1.05rem;
      margin: 1.75em 0 .75em;
    }
  }
</style>
