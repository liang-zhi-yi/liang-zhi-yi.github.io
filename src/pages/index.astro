---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSheep from '../components/home/HeroSheep.astro';
import { formatDate } from '../utils/date';

const [blogPosts, lifeEntries, projects, collections] = await Promise.all([
  getCollection('blog', ({ data }) => !data.draft),
  getCollection('life', ({ data }) => !data.draft),
  getCollection('projects'),
  getCollection('collections')
]);

const toTime = (date?: Date) => date?.getTime() || 0;
const withContentTime = <T extends { data: { pubDate?: Date; updatedDate?: Date } }>(item: T) => Math.max(toTime(item.data.updatedDate), toTime(item.data.pubDate));

// 按更新/上传时间排序各集合，保证新上传或新修改内容优先显示
const sortedBlogPosts = blogPosts.sort((a, b) => withContentTime(b) - withContentTime(a));
const sortedLifeEntries = lifeEntries.sort((a, b) => withContentTime(b) - withContentTime(a));
const sortedProjects = projects.sort((a, b) => withContentTime(b) - withContentTime(a));
const sortedCollections = collections.sort((a, b) => withContentTime(b) - withContentTime(a));

const siteStats = [
  ['Notes', blogPosts.length],
  ['Life', lifeEntries.length],
  ['Works', projects.length],
  ['Pins', collections.length]
];

const timelineItems = [
  ...sortedBlogPosts.map((post) => ({
    title: post.data.title,
    description: post.data.description,
    date: new Date(withContentTime(post)),
    href: `/blog/${post.id.replace(/\.(md|mdx)$/, '')}/`,
    type: '技术笔记',
    mark: 'Tech',
    tone: 'honey',
    meta: post.data.category || '技术'
  })),
  ...sortedLifeEntries.map((entry) => ({
    title: entry.data.title,
    description: entry.data.description || '生活片段',
    date: new Date(withContentTime(entry)),
    href: `/life/${entry.id.replace(/\.(md|mdx)$/, '')}/`,
    type: '生活记录',
    mark: 'Life',
    tone: 'pink',
    meta: entry.data.mood || '日常'
  })),
  ...sortedProjects.map((project) => ({
    title: project.data.title,
    description: project.data.description,
    date: new Date(withContentTime(project) || new Date('2026-01-01').getTime()),
    href: project.data.demoUrl || project.data.repoUrl || '/projects/',
    type: '作品展示',
    mark: 'Work',
    tone: 'grass',
    meta: project.data.status
  })),
  ...sortedCollections.map((item) => ({
    title: item.data.title,
    description: item.data.description || '收藏条目',
    date: new Date(withContentTime(item) || new Date('2026-01-01').getTime()),
    href: item.data.link || '/collections/',
    type: '兴趣收藏',
    mark: 'Pin',
    tone: 'sky',
    meta: item.data.type
  }))
].sort((a, b) => b.date.getTime() - a.date.getTime());
---
<BaseLayout title="小羊草地 | 慢慢写代码，也慢慢记录生活" description="一个奶黄治愈风的个人博客，收纳技术文章、生活记录、作品展示和兴趣收藏。">
  <HeroSheep />

  <main id="home-sections" class="home-sections" aria-label="首页下方子页面板块">
    <section class="home-directory container reveal-on-scroll" aria-label="博客版块导览">
      <div class="directory-heading">
        <span>Moments Timeline</span>
        <h2>博客动态</h2>
        <p>按时间展示全部内容。</p>
      </div>

      <aside class="home-info-board" aria-label="站点信息看板">
        <div class="board-copy">
          <span>Soft Sheep Feed</span>
          <strong>最新动态</strong>
          <p>{timelineItems.length} 条内容。</p>
        </div>
        <dl class="board-stats">
          {siteStats.map(([label, value]) => <div><dt>{label}</dt><dd>{value}</dd></div>)}
        </dl>
      </aside>

      <div class="moments-feed" aria-label="全部博客动态">
        {timelineItems.map((item) => (
          <a class={`moment-item ${item.tone}`} href={item.href}>
            <time datetime={item.date.toISOString()}>{formatDate(item.date)}</time>
            <span class="moment-dot" aria-hidden="true">{item.mark}</span>
            <span class="moment-copy">
              <span class="moment-type">{item.type} · {item.meta}</span>
              <strong>{item.title}</strong>
              <small>{item.description}</small>
            </span>
            <span class="moment-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-sections {
    position: relative;
    scroll-margin-top: 136px;
    padding: clamp(68px, 8vw, 98px) 0 clamp(76px, 9vw, 118px);
  }

  .home-directory {
    position: relative;
    display: grid;
    gap: clamp(20px, 3vw, 32px);
  }

  .home-directory::before,
  .home-directory::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }

  .home-directory::before {
    inset: 18px auto auto -36px;
    width: min(28vw, 270px);
    height: min(28vw, 270px);
    background: radial-gradient(circle, rgba(255,232,163,.38), transparent 68%);
  }

  .home-directory::after {
    right: -48px;
    bottom: -42px;
    width: min(24vw, 230px);
    height: min(24vw, 230px);
    background: radial-gradient(circle, rgba(207,232,184,.3), transparent 70%);
  }

  .directory-heading {
    display: grid;
    justify-items: center;
    gap: .28rem;
    text-align: center;
  }

  .directory-heading span {
    color: var(--color-caramel);
    font-family: 'Baloo 2', 'Nunito', 'Noto Sans SC', sans-serif;
    font-size: .78rem;
    font-weight: 1000;
    letter-spacing: .22em;
    text-transform: uppercase;
  }

  .directory-heading h2 {
    margin: 0;
    color: #fff3ad;
    font-family: 'Baloo 2', 'Nunito', 'Arial Rounded MT Bold', 'Noto Sans SC', sans-serif;
    font-size: clamp(1.4rem, 3.5vw, 3rem);
    font-weight: 1000;
    line-height: .96;
    letter-spacing: -.045em;
    text-shadow:
      0 5px 0 rgba(201,139,58,.2),
      0 16px 36px rgba(95,75,50,.28),
      0 0 28px rgba(247,201,72,.36);
  }

  .directory-heading p {
    max-width: 560px;
    margin: .1rem 0 0;
    color: var(--text-muted);
    font-size: clamp(.86rem, 1.2vw, .98rem);
    font-weight: 800;
    line-height: 1.7;
    text-shadow: none;
  }

  .home-info-board {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: .95rem 1rem;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    background: rgba(255,253,245,.86);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(14px) saturate(126%);
  }

  :root[data-theme='dark'] .home-info-board { background: rgba(12,12,12,.78); }

  .board-copy { display: grid; gap: .18rem; }
  .board-copy span { color: var(--color-caramel); font-size: .72rem; font-weight: 950; letter-spacing: .16em; text-transform: uppercase; }
  .board-copy strong { color: var(--text-main); font-size: clamp(1.05rem, 1.5vw, 1.3rem); line-height: 1.18; }
  .board-copy p { margin: 0; color: var(--text-muted); font-size: .92rem; }
  .board-stats { display: grid; grid-template-columns: repeat(4, minmax(62px, 1fr)); gap: .5rem; margin: 0; }
  .board-stats div { padding: .55rem .65rem; border-radius: 18px; background: rgba(255,232,163,.34); text-align: center; }
  .board-stats dt { color: var(--text-muted); font-size: .68rem; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
  .board-stats dd { margin: .12rem 0 0; color: var(--text-main); font-family: 'Baloo 2', 'Nunito', sans-serif; font-size: 1.2rem; font-weight: 1000; line-height: 1; }

  .moments-feed {
    position: relative;
    display: grid;
    gap: 12px;
  }

  .moments-feed::before {
    content: '';
    position: absolute;
    left: 118px;
    top: 12px;
    bottom: 12px;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(201,139,58,.26), transparent);
    filter: blur(.2px);
  }

  .moment-item {
    --moment-tint: rgba(255,232,163,.38);
    position: relative;
    display: grid;
    grid-template-columns: 92px 54px minmax(0, 1fr) 36px;
    gap: .85rem;
    align-items: center;
    min-height: 92px;
    padding: .82rem .95rem;
    border: 1px solid var(--border-soft);
    border-radius: 28px;
    background:
      radial-gradient(circle at 92% 16%, rgba(255,255,255,.36), transparent 9rem),
      linear-gradient(145deg, rgba(255,253,245,.86), rgba(255,250,240,.58)),
      linear-gradient(135deg, var(--moment-tint), transparent 70%);
    box-shadow: 0 10px 26px rgba(138,106,63,.08);
  }

  :root[data-theme='dark'] .moment-item { background: rgba(12,12,12,.78); }
  .moment-item:hover { transform: translateY(-3px) scale(1.006); box-shadow: var(--shadow-lift); }
  .moment-item.honey { --moment-tint: rgba(255,232,163,.48); }
  .moment-item.pink { --moment-tint: rgba(255,214,223,.44); }
  .moment-item.grass { --moment-tint: rgba(207,232,184,.48); }
  .moment-item.sky { --moment-tint: rgba(205,239,255,.48); }

  .moment-item time {
    color: var(--text-muted);
    font-size: .82rem;
    font-weight: 900;
    text-align: right;
  }

  .moment-dot {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 19px 23px 18px 24px;
    background: rgba(255,232,163,.72);
    color: #6e4c1f;
    font-family: 'Baloo 2', 'Nunito', sans-serif;
    font-size: .78rem;
    font-weight: 1000;
    box-shadow: inset 0 -4px 0 rgba(201,139,58,.12), 0 8px 18px rgba(138,106,63,.1);
  }

  .moment-copy { display: grid; gap: .12rem; min-width: 0; }
  .moment-type { color: var(--color-caramel); font-size: .76rem; font-weight: 950; letter-spacing: .04em; }
  .moment-copy strong { color: var(--text-main); font-size: clamp(1rem, 1.45vw, 1.28rem); line-height: 1.2; }
  .moment-copy small { color: var(--text-muted); font-size: .88rem; line-height: 1.55; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .moment-arrow { display: grid; place-items: center; width: 34px; height: 34px; border-radius: 14px; background: rgba(255,232,163,.4); color: #6e4c1f; font-weight: 1000; }

  @media (max-width: 900px) {
    .home-sections { scroll-margin-top: 100px; }
    .home-info-board { grid-template-columns: 1fr; }
    .board-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .moments-feed::before { left: 88px; }
    .moment-item { grid-template-columns: 70px 46px minmax(0, 1fr) 32px; }
    .moment-dot { width: 44px; height: 44px; font-size: .68rem; }
  }

  @media (max-width: 600px) {
    .moments-feed::before { display: none; }
    .moment-item { grid-template-columns: 1fr 34px; gap: .55rem; }
    .moment-item time,
    .moment-dot { display: none; }
  }
</style>
