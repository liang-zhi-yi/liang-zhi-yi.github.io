---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/date';

// 获取站点统计数据
const [blogPosts, lifeEntries, projects, collections] = await Promise.all([
  getCollection('blog', ({ data }) => !data.draft),
  getCollection('life', ({ data }) => !data.draft),
  getCollection('projects'),
  getCollection('collections')
]);

// 计算总字数（估算）
const totalWordCount = blogPosts.reduce((acc, post) => {
  const body = post.body || '';
  return acc + body.length;
}, 0) + lifeEntries.reduce((acc, entry) => {
  const body = entry.body || '';
  return acc + body.length;
}, 0);

// 格式化字数显示
const formatNumber = (num: number) => {
  if (num >= 10000) {
    return (num / 10000).toFixed(1) + '万';
  }
  return num.toLocaleString();
};

// 获取最新更新时间
const allDates = [
  ...blogPosts.map(p => p.data.pubDate),
  ...lifeEntries.map(e => e.data.pubDate),
  ...projects.map(p => p.data.pubDate),
  ...collections.map(c => c.data.pubDate || new Date('2026-05-27'))
];
const latestUpdate = allDates.length > 0 ? new Date(Math.max(...allDates.map(d => d.getTime()))) : new Date();


