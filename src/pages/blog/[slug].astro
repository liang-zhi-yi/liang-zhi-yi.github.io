---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const toTime = (date?: Date) => date?.getTime() || 0;
  const withContentTime = <T extends { data: { pubDate?: Date; updatedDate?: Date } }>(item: T) => Math.max(toTime(item.data.updatedDate), toTime(item.data.pubDate));
  // 按更新/上传时间排序，保持详情页上一篇/下一篇与列表一致
  const sortedPosts = posts.sort((a, b) => withContentTime(b) - withContentTime(a));
  
  return sortedPosts.map((post, index) => {
    const prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    const nextPost = index > 0 ? sortedPosts[index - 1] : null;
    return { 
      params: { slug: post.id.replace(/\.(md|mdx)$/, '') }, 
      props: { post, prevPost, nextPost } 
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  cover={post.data.cover}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</PostLayout>
