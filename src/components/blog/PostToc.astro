<aside class="toc soft-card" id="post-toc" aria-label="文章目录" data-post-toc>
  <div class="toc-header">
    <strong class="toc-title">☰ 目录</strong>
    <span class="toc-progress" data-toc-progress>0%</span>
  </div>
  <div class="toc-scroll" data-toc-scroll>
    <div class="toc-rail" aria-hidden="true">
      <span class="toc-marker" data-toc-marker></span>
    </div>
    <nav class="toc-list" aria-label="文章章节导航" data-toc-list></nav>
  </div>
</aside>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const content = document.querySelector('[data-post-content]');
  const toc = document.querySelector('[data-post-toc]');
  const tocScroll = document.querySelector('[data-toc-scroll]');
  const tocList = document.querySelector('[data-toc-list]');
  const marker = document.querySelector('[data-toc-marker]');
  const progressEl = document.querySelector('[data-toc-progress]');

  if (content && toc && tocScroll && tocList && marker) {
    const headings = Array.from(content.querySelectorAll('h2, h3'));
    const slugCounts = new Map();

    const slugify = (text) => {
      const base = text
        .trim()
        .toLowerCase()
        .replace(/[^\p{L}\p{N}]+/gu, '-')
        .replace(/^-+|-+$/g, '') || 'section';
      const count = slugCounts.get(base) || 0;
      slugCounts.set(base, count + 1);
      return count ? `${base}-${count + 1}` : base;
    };

    headings.forEach((heading) => {
      if (!heading.id) heading.id = slugify(heading.textContent || 'section');

      const link = document.createElement('a');
      const level = heading.tagName.toLowerCase();
      link.href = `#${heading.id}`;
      link.textContent = heading.textContent || '';
      link.className = `toc-link toc-link-${level}`;
      link.dataset.targetId = heading.id;
      link.dataset.level = level;
      tocList.append(link);
    });

    if (!headings.length) {
      toc.setAttribute('hidden', '');
    } else {
      const links = Array.from(tocList.querySelectorAll('a'));
      let activeId = headings[0]?.id || '';
      let ticking = false;

      const moveMarkerTo = (link) => {
        const scrollRect = tocScroll.getBoundingClientRect();
        const linkRect = link.getBoundingClientRect();
        const center = linkRect.top - scrollRect.top + tocScroll.scrollTop + linkRect.height / 2;
        marker.style.transform = `translateY(${Math.max(0, center - 6)}px)`;
      };

      const setActive = (id, shouldScrollToc = true) => {
        const activeLink = links.find((link) => link.dataset.targetId === id) || links[0];
        if (!activeLink) return;
        activeId = activeLink.dataset.targetId || id;

        links.forEach((link) => {
          const isActive = link === activeLink;
          link.classList.toggle('is-active', isActive);
          link.setAttribute('aria-current', isActive ? 'true' : 'false');
        });

        moveMarkerTo(activeLink);

        if (shouldScrollToc) {
          activeLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
      };

      const getCurrentHeadingId = () => {
        const offset = 180;
        let current = headings[0];

        for (const heading of headings) {
          const top = heading.getBoundingClientRect().top;
          if (top <= offset) current = heading;
          else break;
        }

        return current.id;
      };

      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = Math.min(100, Math.round((scrollTop / docHeight) * 100));
        if (progressEl) progressEl.textContent = `${progress}%`;
      };

      const syncByScroll = () => {
        ticking = false;
        const id = getCurrentHeadingId();
        if (id && id !== activeId) setActive(id);
        else {
          const activeLink = links.find((link) => link.dataset.targetId === activeId);
          if (activeLink) moveMarkerTo(activeLink);
        }
        updateProgress();
      };

      const requestSync = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(syncByScroll);
      };

      links.forEach((link) => {
        link.addEventListener('click', (event) => {
          const id = link.dataset.targetId;
          const target = id ? document.getElementById(id) : null;
          if (!target) return;

          // 阻止默认行为，使用平滑滚动
          event.preventDefault();
          setActive(id);
          target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
          history.replaceState(null, '', `#${id}`);
        });
      });

      const initialHashId = decodeURIComponent(location.hash.slice(1));
      const initialHeading = headings.find((heading) => heading.id === initialHashId);
      setActive(initialHeading?.id || headings[0]?.id, false);
      updateProgress();

      window.addEventListener('scroll', requestSync, { passive: true });
      window.addEventListener('resize', () => setActive(activeId, false));
      tocScroll.addEventListener('scroll', () => {
        const activeLink = links.find((link) => link.dataset.targetId === activeId);
        if (activeLink) moveMarkerTo(activeLink);
      }, { passive: true });
      window.addEventListener('load', () => {
        setActive(initialHeading?.id || getCurrentHeadingId(), false);
        updateProgress();
      });
    }
  }
</script>

<style>
  /* ===== 目录容器 ===== */
  .toc {
    display: none;
    position: sticky;
    top: 100px;
    width: 100%;
    max-height: calc(100vh - 140px);
    padding: .88rem .7rem .88rem .78rem;
    background: rgba(255, 253, 245, .9);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(247, 201, 72, .2);
    box-shadow: 0 8px 32px rgba(138, 106, 63, .06);
    overflow: hidden;
    transition: all 300ms ease;
  }

  :root[data-theme='dark'] .toc {
    background: rgba(12, 12, 12, .86);
    border-color: rgba(255, 224, 138, .12);
  }

  /* 桌面端显示 */
  @media (min-width: 1100px) {
    .toc {
      display: block;
      width: 200px;
    }
  }

  @media (min-width: 1280px) {
    .toc {
      width: 220px;
    }
  }

  /* 移动端展开状态 */
  .toc.is-mobile-open {
    display: block;
    position: fixed;
    top: auto;
    left: 12px;
    right: 12px;
    bottom: 12px;
    z-index: 100;
    max-height: 70vh;
    animation: tocSlideUp 300ms ease-out;
  }

  @keyframes tocSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 目录头部 */
  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .7rem;
    padding-bottom: .52rem;
    border-bottom: 1px solid rgba(247, 201, 72, .2);
  }

  :root[data-theme='dark'] .toc-header {
    border-bottom-color: rgba(255, 224, 138, .12);
  }

  .toc-title {
    color: var(--text-main);
    font-size: 0.7rem;
    font-weight: 950;
    line-height: 1.3;
  }

  .toc-progress {
    color: var(--color-caramel);
    font-size: 0.56rem;
    font-weight: 850;
    padding: .2rem .5rem;
    border-radius: 999px;
    background: rgba(247, 201, 72, .15);
  }

  /* 目录滚动区 */
  .toc-scroll {
    position: relative;
    max-height: calc(100vh - 220px);
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: .18rem .18rem .18rem .92rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(201, 139, 58, .3) transparent;
  }

  .toc-scroll::-webkit-scrollbar { width: 5px; }
  .toc-scroll::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: rgba(201, 139, 58, .25);
  }
  .toc-scroll::-webkit-scrollbar-track { background: transparent; }

  /* 目录轨道和标记 */
  .toc-rail {
    position: absolute;
    left: .25rem;
    top: .5rem;
    bottom: .5rem;
    width: 2px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(201, 139, 58, .08), rgba(201, 139, 58, .2), rgba(201, 139, 58, .08));
    pointer-events: none;
  }

  .toc-marker {
    position: absolute;
    left: 50%;
    top: 0;
    width: 10px;
    height: 10px;
    border: 2px solid rgba(255, 253, 245, .96);
    border-radius: 999px;
    background: rgba(247, 190, 108, .96);
    box-shadow: 0 0 0 3px rgba(255, 232, 163, .3), 0 2px 8px rgba(138, 106, 63, .15);
    transform: translate(-50%, 0);
    transition: transform 200ms ease-out;
  }

  :root[data-theme='dark'] .toc-marker {
    border-color: rgba(12, 12, 12, .88);
    background: rgba(255, 224, 138, .85);
    box-shadow: 0 0 0 3px rgba(255, 224, 138, .15);
  }

  /* 目录列表 */
  .toc-list {
    display: grid;
    gap: .18rem;
    scroll-behavior: smooth;
  }

  /* 目录链接 */
  .toc-link {
    display: block;
    padding: .35rem .42rem;
    border-radius: 7px;
    color: var(--text-muted);
    line-height: 1.42;
    text-decoration: none;
    transition: all 180ms ease;
    border-left: 2px solid transparent;
  }

  .toc-link-h2 {
    font-size: 0.47rem;
    font-weight: 850;
  }

  .toc-link-h3 {
    margin-left: .52rem;
    padding-left: .36rem;
    font-size: 0.43rem;
    font-weight: 600;
    opacity: .9;
  }

  .toc-link:hover {
    color: var(--color-caramel);
    background: rgba(255, 232, 163, .18);
    transform: translateX(2px);
  }

  .toc-link.is-active {
    color: var(--text-main);
    background: rgba(255, 232, 163, .32);
    border-left-color: rgba(247, 201, 72, .7);
    font-weight: 900;
  }

  :root[data-theme='dark'] .toc-link.is-active {
    background: rgba(255, 224, 138, .12);
    border-left-color: rgba(255, 224, 138, .5);
  }
</style>
