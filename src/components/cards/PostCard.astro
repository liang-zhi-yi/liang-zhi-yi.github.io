---
import { formatDate } from '../../utils/date';

export interface Props {
  href: string;
  title: string;
  description?: string;
  tags?: string[];
  date?: Date;
  eyebrow?: string;
}
const { href, title, description, tags = [], date, eyebrow = '技术文章' } = Astro.props;
---
<a class="post-card soft-card reveal-on-scroll" href={href}>
  <span class="card-eyebrow">{eyebrow}</span>
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  <div class="card-foot">
    {date && <time datetime={date.toISOString()}>{formatDate(date)}</time>}
    <span>{tags.slice(0, 2).map((tag) => `#${tag}`).join(' ')}</span>
  </div>
</a>

<style>
  .post-card { display: flex; min-height: 230px; flex-direction: column; padding: 1.35rem; color: var(--text-main); }
  .card-eyebrow { color: var(--text-muted); font-weight: 900; font-size: .9rem; }
  .post-card h3 { margin: .65rem 0 .5rem; font-size: 1.38rem; line-height: 1.25; }
  .post-card p { margin: 0; color: var(--text-muted); }
  .card-foot { display: flex; justify-content: space-between; gap: .8rem; margin-top: auto; padding-top: 1.2rem; color: var(--text-muted); font-size: .9rem; font-weight: 800; }
</style>
